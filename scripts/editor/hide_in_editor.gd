@tool
class_name HideInEditor
extends Node
## Дочерний узел-утилита: прячет РОДИТЕЛЯ в редакторе, показывает в игре.
## Вешается на то, что мешает редактированию сверху (напр. потолок уровня):
## в редакторе родитель невидим (виден пол/предметы), в запущенной игре — виден.
## Видимость — единственное, что трогаем; коллизия родителя остаётся как есть.

func _enter_tree() -> void:
	var p := get_parent()
	if p is Node3D:
		(p as Node3D).visible = not Engine.is_editor_hint()
