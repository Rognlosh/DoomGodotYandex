class_name Episode
extends Resource
## Эпизод кампании: название + упорядоченный список уровней + текст концовки.
## Ресурс-конфиг в стиле AmmoType/SpriteAnimation: эпизоды настраиваются данными
## в инспекторе (массив на game.tscn), при добавлении эпизода код не пишем.
##
## Модель «классика DOOM»: внутри эпизода лоадаут переносится между уровнями,
## новый эпизод стартует со свежим игроком (кулак + пистолет) — сессия играет
## ровно один эпизод, поэтому сброс происходит сам собой при её пересоздании.

## Название эпизода: кнопка на экране выбора и заголовок концовки.
@export var title: String = ""

## Уровни эпизода по порядку. На каждой карте обязателен выход (LevelExit —
## прямым узлом или маркером exit на слое Entities).
@export var levels: Array[PackedScene] = []

## Текст на экране «Эпизод пройден». Пусто — подставится нейтральная фраза.
@export_multiline var ending_text: String = ""
